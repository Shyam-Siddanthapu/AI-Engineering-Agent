@page
@model AiAgent.Api.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <div>
        <h1>AI Engineering Workflow Agent</h1>
        <p>Analyze incidents, plan fixes, and generate tests with a clean architecture pipeline.</p>
    </div>
</section>

<section class="panel chat-main">
    <form method="post" asp-page="/Results" id="agentForm" class="form-grid" novalidate>
        <input type="hidden" asp-for="ConversationId" />
        <div class="step-card">
            <label>
                Repository URL
                <input asp-for="RepositoryUrl" placeholder="https://github.com/org/repo" required />
                <span class="field-error" data-error-for="RepositoryUrl"></span>
            </label>
            <div class="chat-input">
                <label class="chat-input-label">
                    Task
                    <div class="chat-input-container">
                        <textarea asp-for="Task" rows="6" class="task-input" placeholder="Describe your task, paste code, SQL, or ask anything..." required></textarea>
                    </div>
                    <span class="field-error" data-error-for="Task"></span>
                </label>
            </div>
        </div>
        <div class="step-card">
            <div class="step-stack">
                <label>
                    Provider
                    <select asp-for="Provider" id="providerSelect">
                        <option value="Ollama">Ollama</option>
                        <option value="AzureOpenAI">Azure OpenAI</option>
                        <option value="Groq">Groq</option>
                        <option value="Mock">Mock</option>
                    </select>
                </label>
                <div id="mockNotice" class="mock-notice hidden">Mock mode enabled (no external AI required)</div>
                <label id="modelRow">
                    Model
                    <select asp-for="Model" id="modelSelect"></select>
                </label>
                <label id="apiKeyRow">
                    API Key
                    <input asp-for="ApiKey" type="password" placeholder="Required for Azure/Groq" />
                </label>
            </div>
        </div>
        <div class="form-actions full-width">
            <button type="submit" class="primary primary-large" id="submitButton">
                <span class="button-text">Execute</span>
                <span class="button-spinner" aria-hidden="true"></span>
            </button>
        </div>
    </form>
</section>

<div id="spinner" class="spinner hidden">
    <div class="spinner-ring"></div>
    <span>Processing... Please wait</span>
</div>

@section Scripts {
    <script>
        const form = document.getElementById('agentForm');
        const spinner = document.getElementById('spinner');
        const providerSelect = document.getElementById('providerSelect');
        const modelSelect = document.getElementById('modelSelect');
        const modelRow = document.getElementById('modelRow');
        const apiKeyRow = document.getElementById('apiKeyRow');
        const mockNotice = document.getElementById('mockNotice');
        const apiKeyInput = apiKeyRow.querySelector('input');
        const taskInput = document.querySelector('textarea[name="Task"]');
        const submitButton = document.getElementById('submitButton');
        const buttonText = submitButton.querySelector('.button-text');
        const buttonSpinner = submitButton.querySelector('.button-spinner');

        const models = {
            Ollama: ["llama3", "mistral", "phi"],
            AzureOpenAI: ["gpt-4o-mini", "gpt-35-turbo"],
            Groq: ["llama3-70b-8192"],
            Mock: ["default"]
        };

        const updateModels = () => {
            const provider = providerSelect.value;
            const modelList = models[provider] || ["default"];
            const current = modelSelect.value;
            modelSelect.innerHTML = "";
            for (const model of modelList) {
                const option = document.createElement('option');
                option.value = model;
                option.textContent = model;
                modelSelect.appendChild(option);
            }

            if (current && modelList.includes(current)) {
                modelSelect.value = current;
            } else if (modelList.length > 0) {
                modelSelect.value = modelList[0];
            }
        };

        const updateApiKeyVisibility = () => {
            const provider = providerSelect.value;
            const needsKey = provider === 'AzureOpenAI' || provider === 'Groq';
            apiKeyRow.style.display = needsKey ? 'block' : 'none';
            apiKeyInput.disabled = !needsKey || provider === 'Mock';
            if (!needsKey || provider === 'Mock') {
                apiKeyInput.value = '';
            }
        };

        const updateModelVisibility = () => {
            const provider = providerSelect.value;
            const showModels = provider !== 'Mock';
            modelRow.style.display = showModels ? 'block' : 'none';
            modelSelect.disabled = !showModels;
        };

        const updateMockNotice = () => {
            const provider = providerSelect.value;
            if (provider === 'Mock') {
                mockNotice.classList.remove('hidden');
            } else {
                mockNotice.classList.add('hidden');
            }
        };

        providerSelect.addEventListener('change', () => {
            updateModels();
            updateApiKeyVisibility();
            updateModelVisibility();
            updateMockNotice();
        });

        updateModels();
        updateApiKeyVisibility();
        updateModelVisibility();
        updateMockNotice();

        form.addEventListener('submit', () => {
            spinner.classList.remove('hidden');
            submitButton.setAttribute('disabled', 'disabled');
            buttonText.textContent = 'Processing...';
            buttonSpinner.classList.add('visible');
            sessionStorage.setItem('focusTaskOnReturn', 'true');
        });

        window.addEventListener('pageshow', () => {
            if (sessionStorage.getItem('focusTaskOnReturn') === 'true' && taskInput) {
                taskInput.focus();
                sessionStorage.removeItem('focusTaskOnReturn');
            }
            submitButton.removeAttribute('disabled');
            buttonText.textContent = 'Execute';
            buttonSpinner.classList.remove('visible');
        });

        const autoResize = () => {
            if (!taskInput) {
                return;
            }

            taskInput.style.height = 'auto';
            const nextHeight = Math.min(taskInput.scrollHeight, 400);
            taskInput.style.height = `${Math.max(nextHeight, 120)}px`;
        };

        if (taskInput) {
            taskInput.addEventListener('input', () => {
                autoResize();
            });
            taskInput.addEventListener('keydown', (event) => {
                if (event.key === 'Enter' && (event.ctrlKey || event.metaKey)) {
                    event.preventDefault();
                    form.requestSubmit();
                }
            });
            autoResize();
        }


    </script>
}
